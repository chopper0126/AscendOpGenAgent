{
  "name": "NPUKernelbench",
  "version": "1.0.0",
  "description": "NPU算子Benchmark数据集，用于评估Ascend C代码生成能力",
  "operators": ["softmax", "gelu", "layernorm", "matmul", "conv2d"],
  "default_test_cases": 10,
  "timeout_seconds": 600,
  "config": {
    "correctness": {
      "atol": 1e-02,
      "rtol": 1e-02
    },
    "performance": {
      "warmup_iterations": 10,
      "test_iterations": 100
    }
  }
}
